# AgenticFlow Docker Compose Configuration
# Copy this file to .env and fill in your values.

# --- Ports ---
WEB_PORT=3000          # Web UI (nginx) exposed port
SERVER_PORT=8080       # API server exposed port (also used by daemons)
POSTGRES_PORT=5432     # PostgreSQL exposed port (localhost only)

# --- Database ---
POSTGRES_DB=agenticflow
POSTGRES_USER=agenticflow
POSTGRES_PASSWORD=agenticflow

# --- OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Build ---
VERSION=dev
COMMIT=unknown
